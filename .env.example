# ============================================================
# Pickleball Hub — Environment Variables Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql+asyncpg://pickleball_user:your_strong_password_here@postgres:5432/pickleball
TEST_DATABASE_URL=postgresql+asyncpg://pickleball_user:your_strong_password_here@postgres:5432/pickleball_test

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_64_char_random_hex_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_to_another_64_char_random_hex_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# ── Zalo Official Account ─────────────────────────────────────
# Get from: https://developers.zalo.me/app
ZALO_OA_TOKEN=your_zalo_oa_access_token
ZALO_OA_ID=your_zalo_oa_id
ZALO_APP_ID=your_zalo_app_id
ZALO_APP_SECRET=your_zalo_app_secret

# ── Momo Payment ─────────────────────────────────────────────
# Get from: https://business.momo.vn
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# For production: https://payment.momo.vn/v2/gateway/api/create

# ── ZaloPay ──────────────────────────────────────────────────
# Get from: https://developers.zalopay.vn
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
# For production: https://openapi.zalopay.vn/v2/create

# ── App Settings ─────────────────────────────────────────────
ENVIRONMENT=development
# development | staging | production
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:80
WEBHOOK_BASE_URL=https://your-ngrok-or-production-url.com
# Used for payment gateway callbacks — must be publicly accessible

# ── Frontend (Next.js public vars) ───────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SSE_URL=http://localhost:8000/api/v1/notifications/stream
NEXT_PUBLIC_APP_NAME=Pickleball Hub
